bind `{pwd} /n/src9

bind /n/src9/sys/include/a.out.h /sys/include/a.out.h
bind /n/src9/sys/include/mach.h /sys/include/mach.h
#bind /n/src9/sys/src/libmach/executable.c /sys/src/libmach/executable.c
